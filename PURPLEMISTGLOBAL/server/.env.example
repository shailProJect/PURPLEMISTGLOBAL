# Get this from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Inbox that should receive new enquiries
TO_EMAIL=enquiry@purplemist.global

# Must be an address on a domain you've verified in Resend.
# Until you verify purplemist.global in Resend, use the Resend sandbox
# sender below (mail will only deliver to your own Resend account email).
FROM_EMAIL=Purplemist Global <onboarding@resend.dev>

# Your deployed/dev frontend origin, for CORS
FRONTEND_URL=http://localhost:3000

PORT=5000
